terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "ap-south-1"
}

# VPC
resource "aws_vpc" "demopractice_vpc" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "demopractice-vpc"
  }
}

# Public Subnet
resource "aws_subnet" "demopractice_public_subnet" {
  vpc_id     = aws_vpc.demopractice_vpc.id
  cidr_block = "10.0.0.0/24"

  tags = {
    Name = "demopractice-public-subnet"
  }
}

# Private Subnet
resource "aws_subnet" "demopractice_private_subnet" {
  vpc_id     = aws_vpc.demopractice_vpc.id
  cidr_block = "10.0.1.0/24"

  tags = {
    Name = "demopractice-private-subnet"
  }
}

# Internet Gateway
resource "aws_internet_gateway" "demopractice_igw" {
  vpc_id = aws_vpc.demopractice_vpc.id

  tags = {
    Name = "demopractice-igw"
  }
}

# Public Route Table
resource "aws_route_table" "demopractice_public_rtb" {
  vpc_id = aws_vpc.demopractice_vpc.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.demopractice_igw.id
  }

  tags = {
    Name = "demopractice-public-rtb"
  }
}

# Route Table Association
resource "aws_route_table_association" "demopractice_public_assoc" {
  subnet_id      = aws_subnet.demopractice_public_subnet.id
  route_table_id = aws_route_table.demopractice_public_rtb.id
}